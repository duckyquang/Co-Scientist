# Copy to repo root as deploy/oracle/.env (or export before compose).
#   cp deploy/oracle/.env.example deploy/oracle/.env

# Public hostname for the API (A record → Oracle VM public IP).
# Example: api.yourdomain.com
API_DOMAIN=api.yourdomain.com

# GitHub Pages origin allowed to call the API with user-provided keys.
CORS_ORIGINS=https://duckyquang.github.io,http://localhost:5173

# Option 2 (cloud): users paste API keys in the browser — leave server keys empty.
# Option 1 (local engine on VM): uncomment and set if you also want server-side keys.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
