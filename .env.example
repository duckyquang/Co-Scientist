# LLM provider keys — set the one matching `[llm] provider` in your config.
#   provider = "anthropic"   → ANTHROPIC_API_KEY
#   provider = "openai"      → OPENAI_API_KEY
#   provider = "openrouter"  → OPENROUTER_API_KEY
#   provider = "gemini"      → GEMINI_API_KEY
#   provider = "groq"        → GROQ_API_KEY
#   provider = "together"    → TOGETHER_API_KEY
#   provider = "mistral"     → MISTRAL_API_KEY
#   provider = "ollama"      → (no key needed)
#   provider = "openai_compatible" → OPENAI_API_KEY (set [llm.openai] base_url)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
# OPENAI_BASE_URL=                  # optional; overrides [llm.openai] base_url

# Embeddings (Voyage primary, OpenAI fallback — reuses OPENAI_API_KEY above)
VOYAGE_API_KEY=

# Web search (Tavily primary, Brave fallback). The web_search tool auto-activates
# only when one of these is set; OpenAlex / PubMed / arXiv / Europe PMC always work
# with no key.
TAVILY_API_KEY=
BRAVE_API_KEY=

# Optional: improves PubMed rate limits (OpenAlex works keyless; OPENALEX_API_KEY
# is only for the paid premium tier and is not required).
NCBI_API_KEY=
OPENALEX_API_KEY=
